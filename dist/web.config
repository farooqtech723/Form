<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <rewrite>
            <rules>
                <rule name="CleanWebhook" stopProcessing="true">
                    <match url="^api/webhook/?$" />
                    <action type="Rewrite" url="api/webhook.js" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
